---
import Link from '@/components/Link.astro'
import Image from 'astro/components/Image.astro'
import type { CollectionEntry } from 'astro:content'

type Props = {
  project: CollectionEntry<'projects'>
}

const { project } = Astro.props
const isHighlighted = project.data.highlighted ?? false
---

<div
  class:list={[
    'not-prose rounded-md border p-4 transition-colors duration-300 ease-in-out hover:bg-secondary/30',
    isHighlighted && 'border-primary/40 bg-primary/5 shadow-lg shadow-primary/10',
  ]}
>
  <Link
    href={project.data.link}
    class="block"
    external
    class="group flex flex-col gap-4 sm:flex-row"
  >
    {
      project.data.image && (
        <div class:list={[
          'w-full sm:flex-shrink-0',
          isHighlighted ? 'sm:max-w-[280px]' : 'sm:max-w-[200px]',
        ]}>
          <Image
            src={project.data.image}
            alt={project.data.name}
            width={1200}
            height={630}
            class="rounded-sm object-cover grayscale transition-all group-hover:grayscale-0"
          />
        </div>
      )
    }
    <div class="flex-grow">
      <div class="mb-1 flex items-center gap-2">
        <h3 class:list={['font-semibold', isHighlighted ? 'text-xl' : 'text-lg']}>
          {project.data.name}
        </h3>
        {isHighlighted && (
          <span class="inline-flex items-center rounded-full bg-primary/15 px-2.5 py-0.5 text-xs font-medium text-primary">
            ★ Featured
          </span>
        )}
      </div>
      <p class="mb-2 text-sm text-muted-foreground">
        {project.data.description}
      </p>
      {
        isHighlighted && project.data.techStack && (
          <div class="mt-3 space-y-2">
            {project.data.techStack.map((group: any) => (
              <div>
                <p class="mb-1 text-xs font-semibold uppercase tracking-wide text-primary/70">
                  {group.category}
                </p>
                <div class="flex flex-wrap gap-1.5">
                  {group.items.map((item: string) => (
                    <span class="inline-flex items-center rounded-md border border-border bg-secondary/40 px-2 py-0.5 text-xs text-muted-foreground">
                      {item}
                    </span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        )
      }
    </div>
  </Link>
</div>
